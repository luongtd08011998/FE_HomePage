# Chạy local: Next (3000) proxy /api/v1 → Spring (8080). Đổi nếu BE khác port/host.
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_MEDIA_URL=http://127.0.0.1:8080
API_INTERNAL_URL=http://127.0.0.1:8080/api/v1

# Gọi API server thật (tắt 3 dòng trên, bật 3 dòng dưới):
# NEXT_PUBLIC_API_URL=https://125.253.121.171/api/v1
# NEXT_PUBLIC_MEDIA_URL=https://125.253.121.171
# API_INTERNAL_URL=http://127.0.0.1:8080/api/v1
