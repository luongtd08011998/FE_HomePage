# Chạy local: Next (3000) proxy /api/v1 → Spring (8080). Đổi nếu BE khác port/host.
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_MEDIA_URL=http://127.0.0.1:8080
API_INTERNAL_URL=http://127.0.0.1:8080/api/v1

# Gọi API server thật (dùng domain, không dùng IP):
# NEXT_PUBLIC_API_URL=https://beta.toctienltd.vn/api/v1
# NEXT_PUBLIC_MEDIA_URL=https://beta.toctienltd.vn
# API_INTERNAL_URL=http://127.0.0.1:8080/api/v1
