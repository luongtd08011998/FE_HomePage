# Sao chép thành .env.local và chỉnh theo môi trường
# Client: dùng /api/v1 để Next proxy tới Spring (next.config rewrites) — tránh CORS khi dev.
# Hoặc URL đầy đủ tới API công khai (cần CORS trên BE khớp origin).
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_MEDIA_URL=http://localhost:8080
# SSR (Node): gọi trực tiếp Spring. Trùng gốc với rewrite (mặc định 127.0.0.1:8080).
API_INTERNAL_URL=http://127.0.0.1:8080/api/v1
# Tuỳ chọn: gốc Spring khi không muốn suy từ API_INTERNAL_URL (ví dụ Docker: http://backend:8080)
# BACKEND_INTERNAL_ORIGIN=http://127.0.0.1:8080
# Tuỳ chọn: URL gốc site (chia sẻ bài viết). Nếu bỏ trống sẽ suy ra từ request.
# NEXT_PUBLIC_SITE_URL=https://example.com
